# Backend Configuration
PORT=8000
# Local default: school_sessions.db
# Production: use the Supabase session-pooler PostgreSQL connection string.
DATABASE_URL=school_sessions.db
ADMIN_KEY=change-this-admin-key
CORS_ORIGINS=https://pectaa.shahbaznetcafe.com
DEFAULT_PHOTO_LIMIT=50
DISABLE_USAGE_LIMITS=false
U2NET_HOME=./backend/model_cache
PRELOAD_REMBG_MODEL=1
PROCESS_MAX_DIM=960
REMBG_MODEL=u2net
SUBJECT_MARGIN_PX=3

# Frontend Configuration
# For local dev, Vite proxies /api to backend automatically.
# In production, set this to your Render backend URL (e.g. https://your-backend.onrender.com).
VITE_API_URL=
