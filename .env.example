# Backend Configuration
PORT=8000
DATABASE_URL=school_sessions.db
U2NET_HOME=./backend/model_cache
PRELOAD_REMBG_MODEL=1
PROCESS_MAX_DIM=960
REMBG_MODEL=u2net
SUBJECT_MARGIN_PX=3

# Frontend Configuration
# For local dev, Vite proxies /api to backend automatically.
# In production, set this to your Render backend URL (e.g. https://your-backend.onrender.com).
VITE_API_URL=
